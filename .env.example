APP_NAME=moly-llm
ENVIRONMENT=local

SYSTEM_PROMPT=You are Molly, a warm and thoughtful AI companion. Answer clearly, stay concise, and be genuinely helpful. When the user asks for implementation help, be practical and direct.

LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

MEMORY_TOP_K=5
MEMORY_CACHE_TTL_SECONDS=300
MEMORY_SAVE_EVERY_N_TURNS=5
SUPABASE_DB_CONNECTION_STRING=

EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=text-embedding-3-small
MEMORY_LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# 내부 호출 보호(심층방어) — 게이트웨이 INTERNAL_SERVICE_TOKEN과 동일값. 비우면 미강제(로컬).
INTERNAL_SERVICE_TOKEN=
